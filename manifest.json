{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "__MSG_extName__",
  "version": "1.2.0",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; img-src 'self' https: data:; media-src 'self' https: blob:;"
  },
  "description": "__MSG_extDescription__",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "__MSG_extActionTitle__"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://kick.com/*",
    "https://clips.kick.com/*",
    "https://files.kick.com/*",
    "https://stream.kick.com/*",
    "https://*.live-video.net/*",
    "https://*.cloudfront.net/*",
    "http://193.17.180.163:8080/*"
  ]
}
